# ====================== 第一步：全局拉黑所有文件 ======================
# 核心规则：先忽略根目录下所有文件/目录（* 匹配所有）
*

# 例外：不忽略 .gitignore 本身（必须保留，否则规则会失效）
!.gitignore

# 可选：不忽略 README/许可证文件（开源项目建议保留）
!README.md
!LICENSE
!LICENSE.txt
!COPYING

# ====================== 第二步：手动添加你的白名单（修正版） ======================
# 【关键修正】放行目录时需先放行父目录，再放行子文件/子目录
# 规则优先级：父目录必须先放行，否则子文件/子目录的 ! 规则不生效

#任务
!config/
!config/ftbquests
!config/ftbquests/quests/
!config/ftbquests/quests/chapters/
!config/ftbquests/quests/chapters/disksavior.snbt
!config/ftbquests/quests/chapters/extendedaeplu.snbt.disabled
!config/worldedit/
!config/worldedit/schematics/
!config/worldedit/schematics/diban.schem
#kubejs
!Kubejs/
!Kubejs/client_scripts/
!Kubejs/startup_scripts/
!Kubejs/server_scripts/
!Kubejs/client_scripts/*disk*
!Kubejs/startup_scripts/*disk*
!Kubejs/server_scripts/*disk*

!kubejs/assets/
!kubejs/assets/disksavior/
!kubejs/assets/disksavior/**/*
#other
!Disksavior_Changelog.txt
!Disksavior_Changelog.md
!Disksavior_diban.txt

# ====================== 第三步：补充忽略（可选，避免放行无关文件） ======================
# 系统缓存文件（全局忽略，不受白名单影响）
*.DS_Store
Thumbs.db
*.tmp
*.bak
*~
.swp
# 编辑器缓存
.idea/
.vscode/
*.code-workspace
.vs/
# 日志/缓存/构建产物（通用）
logs/
cache/
build/
dist/
node_modules/
export/
compiled/